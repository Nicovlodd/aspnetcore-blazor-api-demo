@page "/specialities/new"
@using MedicalCare.Frontend.Models
@using MedicalCare.Frontend.Services
@inject SpecialityService specialityService
@inject NavigationManager navManager

<h1>Nueva Especialidad</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <EditForm Model="@speciality" OnValidSubmit="Save">
            <div class="mb-3">
                <label class="form-label">Nombre de la Especialidad</label>
                <InputText class="form-control" @bind-Value="speciality.Speciality_Name" required />
            </div>
            <button type="submit" class="btn btn-primary">Guardar</button>
            <button type="button" class="btn btn-secondary ms-2" @onclick="GoBack">Cancelar</button>
        </EditForm>
    </div>
</div>

@code {
    private Speciality speciality = new Speciality();

    private async Task Save()
    {
        var success = await specialityService.CreateSpecialityAsync(speciality);
        if (success) navManager.NavigateTo("/specialities");
    }

    private void GoBack()
    {
        navManager.NavigateTo("/specialities");
    }
}