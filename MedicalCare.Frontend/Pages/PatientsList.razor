@page "/patients"
@using MedicalCare.Frontend.Models
@using MedicalCare.Frontend.Services
@inject PatientService patientService
@inject NavigationManager navManager
@inject IJSRuntime JS

<h1>Gestión de Pacientes</h1>
<hr />

<div class="card mb-4 bg-light">
    <div class="card-body">
        <h5>Buscador Universal</h5>
        <div class="row g-3">
            <div class="col-md-5">
                <input type="text" class="form-control" placeholder="Buscar por Nombre..." @bind="searchName" />
            </div>
            <div class="col-md-4">
                <input type="text" class="form-control" placeholder="Buscar por RUT..." @bind="searchRut" />
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button class="btn btn-primary w-100" @onclick="ExecuteSearch">Buscar</button>
                <button class="btn btn-secondary w-100" @onclick="ClearSearch">Limpiar</button>
            </div>
        </div>
    </div>
</div>

<a href="/patients/new" class="btn btn-success mb-3">
    + Nuevo Paciente
</a>

@if (patients == null)
{
    <p><em>Cargando pacientes...</em></p>
}
else if (!patients.Any())
{
    <div class="alert alert-warning">No se encontraron pacientes con los filtros aplicados.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>RUT</th>
                <th>Nombre</th>
                <th>Apellido</th>
                <th>Fecha de Nacimiento</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var patient in patients)
            {
                <tr>
                    <td>@patient.Patient_Id</td>
                    <td>@patient.Patient_RUT</td>
                    <td>@patient.Patient_FirstName</td>
                    <td>@patient.Patient_LastName</td>
                    <td>@patient.Patient_DateOfBirth.ToString("dd/MM/yyyy")</td>
                    <td>
                        <a href="/patients/edit/@patient.Patient_Id" class="btn btn-sm btn-primary">Editar</a>
                        <button class="btn btn-sm btn-danger ms-1" @onclick="() => ConfirmDelete(patient.Patient_Id, patient.Patient_FirstName)">Eliminar</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Patient>? patients;
    private string? searchName;
    private string? searchRut;

    protected override async Task OnInitializedAsync()
    {
        await LoadPatients();
    }

    private async Task LoadPatients()
    {
        patients = await patientService.GetPatientsAsync();
    }

    private async Task ExecuteSearch()
    {
        patients = await patientService.SearchPatientsAsync(searchName, searchRut);
    }

    private async Task ClearSearch()
    {
        searchName = null;
        searchRut = null;
        await LoadPatients(); 
    }

    private async Task ConfirmDelete(int id, string name)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", $"¿Estás seguro de que deseas eliminar a {name}?");
        if (confirmed)
        {
            var success = await patientService.DeletePatientAsync(id);
            if (success)
            {
                await LoadPatients();
            }
        }
    }
}