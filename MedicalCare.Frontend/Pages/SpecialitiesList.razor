@page "/specialities"
@using MedicalCare.Frontend.Models
@using MedicalCare.Frontend.Services
@inject SpecialityService specialityService
@inject IJSRuntime JS
<h1>Gestión de Especialidades</h1>
<hr />

<a href="/specialities/new" class="btn btn-success mb-3">
    + Nueva Especialidad
</a>

@if (specialities == null)
{
    <p><em>Cargando especialidades...</em></p>
}
else if (!specialities.Any())
{
    <div class="alert alert-warning">No hay especialidades registradas.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Nombre de la Especialidad</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var spec in specialities)
            {
                <tr>
                    <td>@spec.Speciality_Id</td>
                    <td>@spec.Speciality_Name</td>
                    <td>
                        <a href="/specialities/edit/@spec.Speciality_Id" class="btn btn-sm btn-primary">Editar</a>
                        <button class="btn btn-sm btn-danger ms-1" @onclick="() => ConfirmDelete(spec.Speciality_Id, spec.Speciality_Name)">Eliminar</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Speciality>? specialities;

    protected override async Task OnInitializedAsync()
    {
        await LoadSpecialities();
    }

    private async Task LoadSpecialities()
    {
        specialities = await specialityService.GetSpecialitiesAsync();
    }

    private async Task ConfirmDelete(int id, string name)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", $"¿Seguro que deseas eliminar la especialidad: {name}?");
        if (confirmed)
        {
            var success = await specialityService.DeleteSpecialityAsync(id);
            if (success) await LoadSpecialities();
        }
    }
}